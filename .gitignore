# -------------------------
# OS files (always ignore)
# -------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------
# Editor / IDE
# -------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.log

# -------------------------
# Environment variables (IMPORTANT)
# Never upload secrets
# -------------------------
.env
.env.*
!.env.example

# -------------------------
# Dependencies
# -------------------------
node_modules/
jspm_packages/
bower_components/

# -------------------------
# Build output
# (React / Vite / Next / etc.)
# -------------------------
dist/
build/
.out/
.next/
.vercel/
.cache/
coverage/

# -------------------------
# Package managers
# -------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json # remove this line if you want lockfile tracked
yarn.lock         # remove if using yarn and want reproducible builds

# -------------------------
# Generated media / temporary exports
# (Optional — remove if you want assets tracked)
# -------------------------
*.mp4
*.zip
*.rar

# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo

# -------------------------
# Mac / Linux temp
# -------------------------
*.tmp
*.temp